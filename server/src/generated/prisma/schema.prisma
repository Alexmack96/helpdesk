generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  Admin
  User
}

enum TransactionType {
  Income
  Expense
}

enum Owner {
  Alex
  Casey
  Joint
}

enum TabDirection {
  IOwe
  TheyOwe
}

enum TabStatus {
  Open
  Settled
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      UserRole  @default(User)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  image     String?
  sessions  Session[]
  accounts  Account[]

  @@map("user")
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  color         String
  isFixed       Boolean       @default(false)
  isDirectDebit Boolean       @default(false)
  transactions  Transaction[]
}

model Transaction {
  id          String          @id @default(cuid())
  description String
  amount      Decimal
  type        TransactionType
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  externalId  String?         @unique
  note        String?
  owner       Owner           @default(Joint)
}

// One staging model per bank — each preserves that bank's raw CSV schema exactly.
// The process step normalises all of them into the shared Transaction model.

model MonzoTransaction {
  transactionId String   @id
  date          String
  time          String
  type          String
  name          String
  emoji         String?
  category      String
  amount        String
  currency      String
  localAmount   String
  localCurrency String
  notesAndTags  String?
  address       String?
  receipt       String?
  description   String
  categorySplit String?
  moneyOut      String?
  moneyIn       String?
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("monzo_transaction")
}

model AmexTransaction {
  transactionId   String   @id
  transactionDate String
  processDate     String
  description     String
  amount          String
  isCredit        Boolean  @default(false)
  foreignCurrency String?
  foreignAmount   String?
  statementDate   String
  owner           String   @default("Alex")
  importedAt      DateTime @default(now())
  status          String   @default("pending")

  @@map("amex_transaction")
}

model BarclaysTransaction {
  id            Int      @id @default(autoincrement())
  date          String
  description   String
  amount        String
  isCredit      Boolean  @default(false)
  statementDate String
  owner         String   @default("Alex")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("barclays_transaction")
}

model SantanderTransaction {
  id            Int      @id @default(autoincrement())
  date          String
  description   String
  moneyIn       String?
  moneyOut      String?
  balance       String
  statementDate String
  owner         String   @default("Alex")
  importedAt    DateTime @default(now())
  status        String   @default("pending")

  @@map("santander_transaction")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Tab {
  id          String       @id @default(cuid())
  person      String
  description String
  amount      Decimal
  direction   TabDirection
  status      TabStatus    @default(Open)
  dueDate     DateTime?
  settledAt   DateTime?
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tab")
}

model InvestmentAccount {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String // pension | crypto | equity | cash | commodity | debt
  rate      Float?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots InvestmentSnapshot[]

  @@map("investment_account")
}

model InvestmentSnapshot {
  id        String   @id @default(cuid())
  accountId String
  date      DateTime
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account InvestmentAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("investment_snapshot")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
